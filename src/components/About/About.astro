---
import { projects } from '../../data/projects';

const tagCounts = projects.reduce((acc, project) => {
  project.tags.forEach((tag) => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const topSkills = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6)
  .map(([tag]) => tag);
---

<section id="about" class="relative py-[clamp(80px,12vw,140px)] bg-bg-alt overflow-hidden">

  <!-- Top border glow -->
  <div class="absolute top-0 left-0 right-0 h-px
              bg-gradient-to-r from-transparent via-neon-purple to-transparent opacity-35"
       aria-hidden="true"></div>

  <div class="container-main">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-[clamp(40px,7vw,90px)] items-center">

      <!-- Text -->
      <div>
        <p class="section-label reveal">Sobre mim</p>
        <h2 class="section-title reveal reveal-delay-1 mb-7">
          Apaixonado por <span class="neon-text">aprender.</span>
        </h2>

        <div class="reveal reveal-delay-2 flex flex-col gap-4 text-muted text-[0.97rem]
                    max-w-[480px] mb-8 leading-[1.8]">
          <p>
            Hey — I'm Caio, a front-end developer with a deep obsession for
            turning complex problems into intuitive, performant UIs. I've spent
            years working across product teams, open-source projects, and
            freelance engagements building things that run fast and feel good.
          </p>
          <p>
            I care equally about the code behind the pixel and the experience in
            front of it. My stack gravitates toward modern web standards, but I
            adapt to whatever gets the best result for the user.
          </p>
        </div>

        <ul class="reveal reveal-delay-3 grid grid-cols-2 gap-x-6 gap-y-[10px]
                   font-mono text-[0.8rem] text-dim list-none">
          {topSkills.map((skill) => (
            <li class="flex items-center gap-[10px]">
              <span class="inline-block w-[5px] h-[5px] rounded-full flex-shrink-0
                           bg-neon-cyan shadow-neon-cyan"></span>
              {skill}
            </li>
          ))}
        </ul>
      </div>

      <!-- Image -->
      <div class="reveal reveal-delay-2 flex flex-col items-end gap-5 md:items-end items-center">

        <div class="image-frame group relative w-full max-w-[340px] rounded overflow-hidden">
          <img
            src="/profile.jpeg"
            alt="Caio — developer portrait"
            loading="lazy"
            class="w-full aspect-[4/5] object-cover block
                   grayscale-[20%] contrast-[1.05]
                   transition-[filter] duration-300
                   group-hover:grayscale-0 group-hover:contrast-100"
          />
          <div class="image-border absolute inset-0 rounded
                      border border-neon-purple/30 transition-all duration-300
                      group-hover:border-neon-cyan/35 pointer-events-none"></div>
        </div>

        <div class="flex items-center gap-2 font-mono text-[0.73rem] text-muted
                    bg-surface border border-border px-4 py-2 rounded-full max-w-max">
          <span class="badge-dot w-[7px] h-[7px] rounded-full flex-shrink-0
                       bg-neon-green shadow-[0_0_8px_var(--color-neon-green)]"></span>
          Open to work
        </div>

      </div>
    </div>
  </div>

</section>

<style>
  .image-border {
    box-shadow: inset 0 0 40px rgba(123,47,255,0.06);
  }
  .image-frame:hover .image-border {
    box-shadow: inset 0 0 40px rgba(0,245,212,0.06);
  }
  .badge-dot {
    animation: pulse-dot 2.4s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.5; transform: scale(0.85); }
  }
</style>
